---
import { Code } from 'astro:components';

type CodeGroupLanguage = 'bash' | 'powershell' | 'shell' | 'javascript' | 'typescript' | 'go' | 'json' | 'yaml' | 'text';

interface CodeGroupItem {
  label: string;
  lang: CodeGroupLanguage;
  code: string;
}

interface Props {
  items: CodeGroupItem[];
}

const { items } = Astro.props;
const uid = `code-group-${Math.random().toString(36).slice(2, 10)}`;
---

<div class="code-group" data-code-group>
  <div class="code-group-tabs" role="tablist" aria-label="Code examples" data-code-group-tabs>
    {items.map((item, index) => (
      <button
        type="button"
        class:list={['code-group-tab', index === 0 && 'code-group-tab-active']}
        data-code-group-tab
        data-target={`${uid}-${index}`}
      >
        {item.label}
      </button>
    ))}
  </div>
  {items.map((item, index) => (
    <div id={`${uid}-${index}`} class:list={['code-group-panel', index === 0 && 'code-group-panel-active']} data-code-group-panel>
      <Code code={item.code} lang={item.lang} themes={{ light: 'one-light', dark: 'github-dark' }} />
    </div>
  ))}
</div>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement) || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const tabs = Array.from(root.querySelectorAll('[data-code-group-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-code-group-panel]'));
    const tabsBar = root.querySelector('[data-code-group-tabs]');

    const indicator = document.createElement('span');
    indicator.className = 'code-group-indicator';
    tabsBar?.appendChild(indicator);

    function positionIndicator(tab, animate) {
      if (!animate) indicator.style.transition = 'none';
      indicator.style.left = tab.offsetLeft + 'px';
      indicator.style.width = tab.offsetWidth + 'px';
      if (!animate) requestAnimationFrame(() => { indicator.style.transition = ''; });
    }

    const active = tabs.find(t => t.classList.contains('code-group-tab-active')) || tabs[0];
    if (active && tabsBar) positionIndicator(active, false);

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        tabs.forEach((item) => item.classList.toggle('code-group-tab-active', item === tab));
        panels.forEach((panel) => panel.classList.toggle('code-group-panel-active', panel.id === target));
        positionIndicator(tab, true);
      });
    });
  })();
</script>
