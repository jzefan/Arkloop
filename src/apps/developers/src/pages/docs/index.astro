---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSidebar } from '@/lib/navigation';

const groups = getSidebar('zh', 'docs');
---

<BaseLayout title="Docs" description="Arkloop 工程文档入口。" locale="zh" pathname="/docs" alternatePath="/en/docs">
  <section class="docs-index-panel">
    <p class="section-kicker">Documentation</p>
    <h1 class="page-title">工程文档</h1>
    <p class="page-copy">覆盖本地启动、架构规范、配置注册表和开源路线图。</p>
  </section>

  <section class="section-block">
    <div class="section-grid">
      {groups.map((group) => (
        <section class="section-grid-item">
          <strong>{group.label}</strong>
          <div class="sidebar-links">
            {group.items.map((item) => (
              <a class="sidebar-link" href={item.href}>{item.label}</a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
