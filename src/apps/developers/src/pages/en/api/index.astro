---
import { getEntry, render } from 'astro:content';
import { findDocTitle, findSidebarLabel } from '@/lib/content';
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getPrevNext } from '@/lib/navigation';

const entry = await getEntry('docs', 'en/api');
if (!entry) throw new Error('Missing en/api/index');
const { Content, headings } = await render(entry);
const pathname = '/en/api';
const title = findDocTitle(entry, findSidebarLabel(pathname, 'en', 'api') ?? 'API');
const { prev, next } = getPrevNext('en', 'api', pathname);
const showSyntheticTitle = headings[0]?.depth !== 1;
---

<DocsLayout title={title} description={entry.data.description} locale="en" pathname={pathname} section="api" headings={headings} prev={prev} next={next} showSyntheticTitle={showSyntheticTitle} alternatePath="/api">
  <Content />
</DocsLayout>
