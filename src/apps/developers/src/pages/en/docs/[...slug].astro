---
import { getCollection, render } from 'astro:content';
import { findDocTitle, findSidebarLabel } from '@/lib/content';
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getPrevNext } from '@/lib/navigation';
import { docsSlugFromId, mirrorEntryId } from '@/lib/routes';

export async function getStaticPaths() {
  const entries = await getCollection('docs', (entry) => !entry.data.draft);
  const zhIds = new Set(entries.filter((entry) => entry.id.startsWith('zh/')).map((entry) => entry.id));

  return entries
    .filter((entry) => entry.id.startsWith('en/') && !entry.id.startsWith('en/api/'))
    .map((entry) => {
      const slug = docsSlugFromId(entry.id, 'en');
      if (!slug) return null;
      const mirrorId = mirrorEntryId(entry.id, 'en');
      const altSlug = docsSlugFromId(mirrorId, 'zh');
      return {
        params: { slug },
        props: {
          entry,
          pathname: `/en/docs/${slug}`,
          alternatePath: zhIds.has(mirrorId) && altSlug ? `/docs/${altSlug}` : null,
        },
      };
    })
    .filter(Boolean);
}

const { entry, pathname, alternatePath } = Astro.props;
const { Content, headings } = await render(entry);
const title = findDocTitle(entry, findSidebarLabel(pathname, 'en', 'docs') ?? 'Documentation');
const { prev, next } = getPrevNext('en', 'docs', pathname);
const showSyntheticTitle = headings[0]?.depth !== 1;
---

<DocsLayout
  title={title}
  description={entry.data.description}
  locale="en"
  pathname={pathname}
  section="docs"
  headings={headings}
  prev={prev}
  next={next}
  showSyntheticTitle={showSyntheticTitle}
  alternatePath={alternatePath}
>
  <Content />
</DocsLayout>
