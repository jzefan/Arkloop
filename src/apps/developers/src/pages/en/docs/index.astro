---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSidebar } from '@/lib/navigation';

const groups = getSidebar('en', 'docs');
---

<BaseLayout title="Docs" description="Entry point for Arkloop documentation." locale="en" pathname="/en/docs" alternatePath="/docs">
  <section class="docs-index-panel">
    <p class="section-kicker">Documentation</p>
    <h1 class="page-title">Documentation</h1>
    <p class="page-copy">Local setup, architecture specifications, configuration registry, and the open-source roadmap.</p>
  </section>

  <section class="section-block">
    <div class="section-grid">
      {groups.map((group) => (
        <section class="section-grid-item">
          <strong>{group.label}</strong>
          <div class="sidebar-links">
            {group.items.map((item) => (
              <a class="sidebar-link" href={item.href}>{item.label}</a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
