---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Arkloop Developers" description="Arkloop developer portal for docs, API reference, and research." locale="en" pathname="/en" alternatePath="/">
  <div class="home-shell">
    <section class="home-landing">
      <h1 class="home-title">Arkloop Developers</h1>
      <p class="home-tagline">Open-source AI agent platform with autonomous execution, intelligent search, and sandboxed runtime.</p>
      <div class="home-actions">
        <a class="primary-button" href="/en/docs/guide">Get started</a>
        <a class="secondary-button" href="/en/api">View API</a>
      </div>
      <nav class="home-aux-links">
        <a href="/research">Research</a>
        <span class="home-aux-sep">/</span>
        <a href="/en/docs/guide">Docs</a>
      </nav>
    </section>

    <section class="home-features">
      <div class="home-feature">
        <h3 class="home-feature-title">Agent Loop</h3>
        <p class="home-feature-desc">Multi-step autonomous execution with planning, reasoning, and tool orchestration. Persistent memory across conversations.</p>
      </div>
      <div class="home-feature">
        <h3 class="home-feature-title">Multi-Model</h3>
        <p class="home-feature-desc">Integrates OpenAI, Anthropic, and any compatible provider. Priority-based routing with rate limit handling.</p>
      </div>
      <div class="home-feature">
        <h3 class="home-feature-title">Sandboxed Execution</h3>
        <p class="home-feature-desc">Isolated environments via Firecracker microVMs or Docker. Python, data analysis, chart generation with strict resource limits.</p>
      </div>
      <div class="home-feature">
        <h3 class="home-feature-title">Browser Automation</h3>
        <p class="home-feature-desc">Headless browser control as a native agent tool. Web interaction, data extraction, and screenshot capture via Playwright.</p>
      </div>
      <div class="home-feature">
        <h3 class="home-feature-title">Custom Personas</h3>
        <p class="home-feature-desc">Specialized agent configs with distinct prompts, tool sets, and behavioral tiers. Supports Lua-based custom executors.</p>
      </div>
      <div class="home-feature">
        <h3 class="home-feature-title">REST + SSE API</h3>
        <p class="home-feature-desc">40+ endpoints covering threads, runs, personas, and providers. Monotonic event ordering with cursor-based continuation.</p>
      </div>
    </section>
  </div>
</BaseLayout>
