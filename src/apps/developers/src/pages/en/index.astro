      </div>
    </div>

    <!-- Contributing -->
    <div class="contrib-card">
      <div class="contrib-left">
        <svg class="contrib-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <div>
          <h2 class="contrib-title">Contributing</h2>
          <p class="contrib-desc">We welcome contributions of all kinds. Even if you're not a developer -- if something feels off, a bit of spacing, a color that doesn't sit right, any tiny detail or even a big-picture direction -- please open an issue. We take every UX detail seriously, and your feedback makes Arkloop better for everyone.</p>
        </div>
      </div>
      <div class="contrib-actions">
        <a class="contrib-btn contrib-btn-primary" href="https://github.com/qqqqqf-q/Arkloop" target="_blank" rel="noopener">GitHub</a>
        <a class="contrib-btn contrib-btn-secondary" href="/en/docs/contributing">Contributing Guide</a>
      </div>
    </div>

    <!-- Section 3: How to use -->
    <div class="section-grid">
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h2 class="section-card-title">Desktop App</h2>
        <p class="section-card-desc">Native app built on Electron + Go sidecar, runs entirely locally. Ships with a complete runtime -- no Docker, no setup, open and go. Auto-updates via GitHub Releases.</p>
        <div class="section-card-platforms">
          <span>macOS</span>
          <span>Linux</span>
          <span>Windows</span>
        </div>
      </div>
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h2 class="section-card-title">Self-hosted</h2>
        <p class="section-card-desc">Full server-side deployment. One-command startup with Docker Compose, pre-built images ready for production. Requires 2+ CPU cores and 4+ GiB RAM.</p>
        <div class="section-code">
          <code>./setup.sh install</code>
        </div>
      </div>
      <div class="section-card">
        <div class="section-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <h2 class="section-card-title">Skill Ecosystem</h2>
        <p class="section-card-desc">Search and import skills from ClawHub, compatible with the OpenClaw SKILL.md format. Custom Personas support independent system prompts, tool sets, and Lua scripts to customize the agent loop.</p>
        <a class="section-card-link" href="/en/docs/skills">Explore the skill ecosystem</a>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const RELEASES_API = 'https://api.github.com/repos/qqqqqf-q/Arkloop/releases/latest';
  const RELEASES_PAGE = 'https://github.com/qqqqqf-q/Arkloop/releases';

  const PLATFORM_PATTERNS: Record<string, string[]> = {
    'darwin-arm64': ['darwin-arm64', 'mac-arm64', 'macos-arm64', 'arm64.dmg', 'arm64.zip'],
    'darwin-x64':   ['darwin-x64', 'mac-x64', 'macos-x64', 'x64.dmg', 'intel.dmg'],
    'win32-x64':    ['win32-x64', 'windows-x64', 'win-x64', '.exe', 'setup.exe'],
    'linux-x64':    ['linux-x64', 'linux-amd64', 'amd64.AppImage', 'linux-x86_64'],
  };

  async function initDownload() {
    let assets: Array<{ name: string; browser_download_url: string }> = [];
    let tag = '';
    try {
      const res = await fetch(RELEASES_API);
      if (res.ok) {
        const data = await res.json();
        assets = data.assets ?? [];
        tag = data.tag_name ?? '';
      }
    } catch {}

    const labelEl = document.getElementById('dl-main-label-en');
    if (labelEl) labelEl.textContent = tag ? `Download ${tag}` : 'Download';

    document.querySelectorAll<HTMLAnchorElement>('a[data-platform]').forEach(link => {
      const platform = link.dataset.platform!;
      const patterns = PLATFORM_PATTERNS[platform] ?? [];
      const asset = assets.find(a =>
        patterns.some(p => a.name.toLowerCase().includes(p.toLowerCase()))
      );
      link.href = asset ? asset.browser_download_url : RELEASES_PAGE;
    });
  }

  const mainBtn = document.getElementById('dl-main-en');
  const dropdown = document.getElementById('dl-dropdown-en');
  if (mainBtn && dropdown) {
    mainBtn.addEventListener('click', () => {
      dropdown.classList.toggle('dl-dropdown-open');
    });
    document.addEventListener('click', (e) => {
      if (!mainBtn.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('dl-dropdown-open');
      }
    });
  }

  initDownload();
</script>

<style>
  :root {
    --guide-line: rgba(255, 255, 255, 0.22);
    --guide-dot: rgba(255, 255, 255, 0.35);
    --guide-label: rgba(255, 255, 255, 0.25);
    --construct-line: rgba(255, 255, 255, 0.15);
    --dimension-line: rgba(255, 255, 255, 0.18);
    --card-bg: transparent;
  }

  :root[data-theme='light'] {
    --guide-line: rgba(0, 0, 0, 0.22);
    --guide-dot: rgba(0, 0, 0, 0.35);
    --guide-label: rgba(0, 0, 0, 0.25);
    --construct-line: rgba(0, 0, 0, 0.15);
    --dimension-line: rgba(0, 0, 0, 0.18);
    --card-bg: #F5F7F6;
  }

  .landing-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 96px 24px 64px;
    gap: 20px;
  }

  .landing-card {
    width: 100%;
    max-width: 1080px;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
  }

  .hero-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 64px 48px 56px;
    gap: 24px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-hero-download {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 24px;
    background: var(--text-strong);
    color: var(--bg-page);
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: opacity 140ms ease;
  }

  .btn-hero-download:hover {
    opacity: 0.8;
  }

  .btn-hero-secondary {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 120ms ease, color 120ms ease;
  }

  .btn-hero-secondary:hover {
    background: var(--bg-surface-soft);
    color: var(--text-strong);
  }

  :root[data-theme='light'] .btn-hero-secondary:hover {
    background: #ebebeb;
  }

  .type-specimen {
    width: 100%;
    max-width: 560px;
  }

  .type-svg {
    width: 100%;
    height: auto;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-strong);
    line-height: 1.15;
  }

  .hero-desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 520px;
  }

  /* Download dropdown */
  .dl-btn-wrap {
    position: relative;
    display: inline-flex;
  }

  .dl-chevron {
    width: 10px;
    height: 10px;
    opacity: 0.7;
  }

  .dl-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 260px;
    background: var(--bg-surface, #1e1e1e);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 6px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.24);
    z-index: 100;
  }

  :root[data-theme='light'] .dl-dropdown {
    background: #ffffff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .dl-dropdown-open {
    display: block;
    animation: dl-slide-down 0.1s ease-out;
  }

  @keyframes dl-slide-down {
    from { opacity: 0; transform: translateX(-50%) translateY(-6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
