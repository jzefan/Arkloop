            GitHub
          </a>
          <a class="btn-hero-secondary" href="https://t.me/Arkloop_io" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248l-1.97 9.289c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L6.514 14.51l-2.948-.924c-.64-.203-.654-.64.136-.95l11.52-4.44c.534-.194 1.001.13.34.052z"/></svg>
            Telegram
