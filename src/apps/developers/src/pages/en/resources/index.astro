---
import BaseLayout from '@/layouts/BaseLayout.astro';

const resources = [
  {
    title: 'GitHub Repository',
    description: 'Arkloop source code, issues, and release history.',
    href: 'https://github.com/qqqqqf-q/Arkloop',
    external: true,
  },
  {
    title: 'Quickstart Guide',
    description: 'Bring up infrastructure and start local development.',
    href: '/en/docs/guide',
  },
  {
    title: 'Deployment Guide',
    description: 'Deploy API, Worker, Gateway, and frontend apps.',
    href: '/en/docs/guide/deployment',
  },
  {
    title: 'Configuration Registry',
    description: 'Platform-level and tenant-level configuration keys.',
    href: '/en/docs/reference/configuration',
  },
  {
    title: 'Research',
    description: 'Runtime and system design papers from the Arkloop team.',
    href: '/research',
  },
  {
    title: 'Security Policy',
    description: 'Report vulnerabilities and review disclosure rules.',
    href: 'https://github.com/qqqqqf-q/Arkloop/blob/main/SECURITY.md',
    external: true,
  },
];
---

<BaseLayout title="Resources" description="Developer entry points for Arkloop." locale="en" pathname="/en/resources" alternatePath="/resources">
  <section class="resources-panel">
    <p class="section-kicker">Resources</p>
    <h1 class="page-title">Developer resources</h1>
    <p class="page-copy">One place for the repository, key docs, research, and security guidance.</p>
  </section>

  <section class="section-block">
    <div class="resource-grid">
      {resources.map((item) => (
        <a class="resource-card" href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
          <h2>{item.title}</h2>
          <p class="resource-description">{item.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
